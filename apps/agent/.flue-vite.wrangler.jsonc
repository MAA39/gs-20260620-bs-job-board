{
  "name": "bs-job-board-agent",
  "main": ".flue-vite/_entry.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": [
        "**/*.js",
        "**/*.mjs"
      ]
    }
  ],
  "find_additional_modules": true,
  "base_dir": "dist/bs_job_board_agent",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bs-job-board-db",
      "database_id": "f64026c1-f6b4-4739-943a-dd7cd57918f7"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "FLUE_ANALYST_AGENT",
        "class_name": "FlueAnalystAgent"
      },
      {
        "name": "FLUE_GENERATE_REPLIES_WORKFLOW",
        "class_name": "FlueGenerateRepliesWorkflow"
      },
      {
        "name": "FLUE_REGISTRY",
        "class_name": "FlueRegistry"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueAnalystAgent"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "FlueGenerateRepliesWorkflow"
      ]
    }
  ],
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json"
}