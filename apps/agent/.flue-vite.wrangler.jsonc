{
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json",
  "name": "bs-job-board-agent",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueAnalystAgent"
      ]
    }
  ],
  "main": ".flue-vite/_entry.ts",
  "durable_objects": {
    "bindings": [
      {
        "name": "FLUE_ANALYST_AGENT",
        "class_name": "FlueAnalystAgent"
      },
      {
        "name": "FLUE_REGISTRY",
        "class_name": "FlueRegistry"
      }
    ]
  }
}